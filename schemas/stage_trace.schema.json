{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rasim-next.local/schemas/stage_trace.schema.json",
  "title": "RASIM Next stage trace manifest",
  "type": "object",
  "required": [
    "schema_version",
    "pack_id",
    "source_provenance",
    "environment",
    "cases"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "pack_id": {
      "type": "string",
      "minLength": 1
    },
    "created_utc": {
      "type": "string",
      "format": "date-time"
    },
    "source_provenance": {
      "type": "object",
      "required": [
        "source_sha256",
        "manuscript_sha256"
      ],
      "properties": {
        "source_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "manuscript_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "source_commit": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": true
    },
    "environment": {
      "type": "object",
      "required": [
        "python",
        "platform",
        "packages",
        "thread_settings",
        "environment_sha256"
      ],
      "properties": {
        "environment_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      },
      "additionalProperties": true
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "case_id",
          "subsystem",
          "classification",
          "inputs",
          "input_sha256",
          "ledger_ids",
          "stages"
        ],
        "properties": {
          "case_id": {
            "type": "string",
            "minLength": 1
          },
          "subsystem": {
            "enum": [
              "coordinates",
              "geometry_optics",
              "mosaic_ewald",
              "ordered_reflectivity",
              "stacking_transition",
              "integration",
              "selection_fitting"
            ]
          },
          "classification": {
            "enum": [
              "MATCH",
              "CORRECTED",
              "NO_ORACLE",
              "UNRESOLVED"
            ]
          },
          "inputs": {
            "type": "object"
          },
          "input_sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "ledger_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "first_divergence_stage": {
            "type": [
              "string",
              "null"
            ]
          },
          "stages": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": [
                "stage_id",
                "array_key",
                "array_sha256",
                "dtype",
                "shape",
                "byte_order",
                "unit",
                "frame",
                "quantity_kind",
                "measure",
                "model_id",
                "parent_ids"
              ],
              "properties": {
                "stage_id": {
                  "type": "string",
                  "minLength": 1
                },
                "array_key": {
                  "type": "string",
                  "minLength": 1
                },
                "array_sha256": {
                  "type": "string",
                  "pattern": "^[0-9a-f]{64}$"
                },
                "dtype": {
                  "type": "string",
                  "minLength": 1
                },
                "shape": {
                  "type": "array",
                  "items": {
                    "type": "integer",
                    "minimum": 0
                  }
                },
                "byte_order": {
                  "enum": [
                    "little",
                    "big",
                    "native",
                    "not_applicable"
                  ]
                },
                "unit": {
                  "type": "string",
                  "minLength": 1
                },
                "frame": {
                  "type": "string",
                  "minLength": 1
                },
                "quantity_kind": {
                  "enum": [
                    "SCALAR",
                    "INDEX",
                    "POINT",
                    "VECTOR",
                    "MATRIX",
                    "AMPLITUDE",
                    "INTENSITY",
                    "IMAGE",
                    "MASK"
                  ]
                },
                "measure": {
                  "enum": [
                    "NONE",
                    "PROBABILITY_DENSITY",
                    "PROBABILITY_MASS",
                    "DIFFERENTIAL_PER_SOLID_ANGLE",
                    "INTEGRATED_EVENT_MASS",
                    "DETECTOR_PIXEL_MASS"
                  ]
                },
                "model_id": {
                  "type": "string",
                  "minLength": 1
                },
                "parent_ids": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "uniqueItems": true
                },
                "rtol": {
                  "type": [
                    "number",
                    "null"
                  ],
                  "minimum": 0
                },
                "atol": {
                  "type": [
                    "number",
                    "null"
                  ],
                  "minimum": 0
                },
                "nan_policy": {
                  "enum": [
                    "forbid",
                    "equal",
                    "masked"
                  ]
                },
                "notes": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            }
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "classification": {
                  "const": "CORRECTED"
                }
              }
            },
            "then": {
              "required": [
                "first_divergence_stage"
              ]
            }
          }
        ],
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
